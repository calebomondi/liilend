# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
HOST=0.0.0.0

# ─── Solana ───────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
PROGRAM_ID=Li1Lend1111111111111111111111111111111111

# ─── Database (Supabase) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── FX Oracle ────────────────────────────────────────
# Primary: Switchboard  |  Fallback: direct aggregator
FX_ORACLE_URL=https://api.switchboard.xyz/v2
FX_CACHE_TTL_SECONDS=300
FX_FALLBACK_URLS=https://api.exchangerate-api.com/v4/latest/USD,https://open.er-api.com/v6/latest/USD

# ─── Liquidation ──────────────────────────────────────
HEALTH_FACTOR_WARN=1.15
HEALTH_FACTOR_LIQUIDATE=1.05
LIQUIDATION_BONUS_BPS=500
LIQUIDATION_POLL_INTERVAL_MS=10000

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret
SIGNED_MESSAGE_VALIDITY_SECONDS=300

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=combined

# ─── Queue ────────────────────────────────────────────
QUEUE_INDEXER_CONCURRENCY=5
QUEUE_LIQUIDATION_CONCURRENCY=3
