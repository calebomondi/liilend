# ── LiiLend Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Solana ─────────────────────────────────────────────────────────────────────
SOLANA_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
WS_URL=wss://api.devnet.solana.com

# Deployer keypair path (relative or absolute)
DEPLOYER_KEYPAIR_PATH=~/.config/solana/id.json

# ── Program ────────────────────────────────────────────────────────────────────
# Set automatically by deploy-devnet.sh; override here if needed.
PROGRAM_ID=BrtmpQXVMryfdrtTQLxFaJtSTa78nULPuxJcQfFznpQc

# ── Authority / Multisig ───────────────────────────────────────────────────────
# Base58 public key of the multisig or cold wallet that will control the protocol
# after initialization. Leave empty to keep deployer as authority.
MULTISIG_AUTHORITY=

# ── Backend ────────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# ── Postgres (indexer / persistent storage) ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=liilend
POSTGRES_USER=liilend
POSTGRES_PASSWORD=changeme

# ── Redis (caching / background jobs) ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Supabase (optional — for off-chain data) ───────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Oracle (Pyth / Switchboard) ────────────────────────────────────────────────
# These are devnet addresses by default. Override for mainnet.
PYTH_SOL_FEED=H6ARHf6YXhGYeQfUzQNGk6rDNnLBQKrenN712K4AQJEG
PYTH_USDC_FEED=Dpw1EAVrSB1ibY1AStoA9C2yKF8F5wJNtBy2jVfXNU8V
PYTH_USDT_FEED=38xoQ4QJkLwQTHzFfKQKFZNPqumLYQoBoq2eXxMfNVR

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=BrtmpQXVMryfdrtTQLxFaJtSTa78nULPuxJcQfFznpQc
